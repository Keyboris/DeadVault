# Copy this file to .env and fill values before running docker compose.
# Required for backend startup
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
OPENAI_API_KEY=replace_with_openai_api_key

# Optional defaults are provided in docker-compose.yml, override as needed
BASE_RPC_URL=https://sepolia.base.org
BASE_CHAIN_ID=84532

# Required only for contract deployment features
HOT_WALLET_PRIVATE_KEY=replace_with_wallet_private_key
FACTORY_CONTRACT_ADDRESS=replace_with_factory_contract_address
